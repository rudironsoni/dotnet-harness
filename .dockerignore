# Docker ignore file for RuleSync-first .NET agent harness
# Optimizes build context size and performance

# ============================================================================
# Git
# ============================================================================
.git
.gitignore
.gitattributes
.gitmodules

# ============================================================================
# Node.js
# ============================================================================
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================================
# Generated outputs (these are produced by RuleSync)
# ============================================================================
.agent
.claude
.codex
.gemini
.opencode
.vscode
.github/agents
.github/instructions
.github/prompts
.github/skills
.github/copilot-instructions.md
.mcp.json
AGENTS.md
CLAUDE.md
GEMINI.md
opencode.json

# ============================================================================
# IDE and editors
# ============================================================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# Build outputs
# ============================================================================
dist
artifacts
bin
obj
*.dll
*.exe
*.pdb
*.nupkg

# ============================================================================
# Test and coverage
# ============================================================================
coverage
.nyc_output
test-results
*.test.log

# ============================================================================
# Temporary files
# ============================================================================
*.tmp
*.temp
*.log
tmp
temp

# ============================================================================
# Documentation build
# ============================================================================
wiki/.vitepress/dist
site

# ============================================================================
# Local environment files
# ============================================================================
.env
.env.local
.env.*.local

# ============================================================================
# Large files not needed for builds
# ============================================================================
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# ============================================================================
# CI/CD artifacts
# ============================================================================
.github/workflows/*.yml.disabled
