{
  "$schema": "https://raw.githubusercontent.com/dyoshikawa/rulesync/refs/heads/main/config-schema.json",
  "targets": [
    "claudecode",
    "copilot",
    "factorydroid",
    "opencode",
    "geminicli",
    "codexcli",
    "antigravity",
    "agentsmd"
  ],
  "features": ["*"],
  "baseDirs": ["."],
  "delete": true,
  "verbose": false,
  "sources": [
    // Declarative source example (disabled until upstream exposes RuleSync-ready skills)
